# SendGrid: https://app.sendgrid.com → Settings → API Keys (Mail Send)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Must be a verified sender in SendGrid (Single Sender Verification or Domain Authentication)
SENDGRID_FROM_EMAIL=noreply@your-verified-domain.com

# Where contact form submissions are delivered
CONTACT_TO_EMAIL=equalify26@gmail.com

# Optional: restrict CORS in production (e.g. https://yoursite.com)
# CORS_ORIGIN=https://yoursite.com

# Server port (default 3001). Vite dev proxies /api here — see vite.config.js
# PORT=3001
